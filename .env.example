# ---------------------------------------------------------------------------
# Beckford Moves – environment variables (Netlify / Vercel / local)
# Copy to .env.local for local dev. In Netlify: Project → Configuration → Environment variables.
# ---------------------------------------------------------------------------

# --- Required for build (if Supabase client is used) ---
# Supabase project: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# --- Contact form (Resend) – optional; form works without, but won't send email ---
# Resend: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Where contact form submissions are sent
CONTACT_TO_EMAIL=sean@example.com
# From address (must be a verified domain in Resend)
CONTACT_FROM_EMAIL=no-reply@beckfordmoves.com

# --- Optional: analytics & Calendly ---
# Google Analytics 4: Admin → Data Streams → your web stream → Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Calendly embed URL, e.g. https://calendly.com/your-username/30min
NEXT_PUBLIC_CALENDLY_URL=

# --- Optional: Notion (only if using /work/notion or Notion-backed content) ---
# Notion: Create integration at https://www.notion.so/my-integrations, then share pages with it
NOTION_TOKEN=secret_xxxxxxxxxxxx

# --- Optional: Supabase service role (only if you add server-side admin/content writes later) ---
# Same project → Settings → API → service_role key (keep secret)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# --- Netlify: set Node version (recommended for Next 16) ---
# In Netlify UI: Environment variables → Add → Key NODE_VERSION, Value 20
# Or add .nvmrc with: 20
